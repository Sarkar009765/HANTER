{
    "productName": "HANTER",
    "version": "1.0.0",
    "identifier": "com.hanter.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "HANTER",
                "width": 1280,
                "height": 800,
                "minWidth": 1024,
                "minHeight": 700,
                "center": true,
                "decorations": true,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' ws://localhost:8000 http://localhost:8000; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi", "dmg", "deb", "appimage"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": ["../../core"],
        "category": "DeveloperTool",
        "shortDescription": "Personal AI Agent Framework",
        "longDescription": "HANTER is a multi-agent AI framework that operates as a digital twin for users. It combines a lightweight desktop UI with a Python-based agent orchestration engine."
    },
    "plugins": {
        "updater": {
            "active": true,
            "endpoints": ["https://api.HANTER.dev/releases"],
            "dialog": true
        }
    }
}
