root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,json,yml,yaml,css,html,md}]
indent_size = 2

[*.py]
indent_size = 4

[*.bat]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
